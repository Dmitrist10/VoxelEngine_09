component tag C_Target();
component  C_Enemy(Entity target, float speed);

#define EP "TestingEnemy"

query = with { C_Enemy, C_Transform }

void OnUpdate(){

    world.query(query, [Entity e, C_Enemy enemy, C_Transform transform]){
        C_Transform targetPos =? enemy.target.Get<C_Transform>() ??
        Logger.Debug("The Target has no Transform component");

        transform.position = Vec3.Lerp(transform.position, targetPos.position, enemy.speed * Time.DeltaTime);
    }

}

