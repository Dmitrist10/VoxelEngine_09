component C_Player(string name); // A simple component

#define EP "PlayersQuery" // defines a EP class

query = with { C_Player() }, with-none { C_Disabled() }; // A simple query

void OnUpdate(){

    world.query(query, [Entity e, C_Player player]){
        Logger.Debug($"entity: {e}, player: {player.name}");        
    }

}


